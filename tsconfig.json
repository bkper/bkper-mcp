{
    "compilerOptions": {
        "target": "es2021",
        "lib": ["es2021"],
        "module": "es2022",
        "moduleResolution": "Bundler",
        "resolveJsonModule": true,
        "allowJs": true,
        "checkJs": false,
        "noEmit": true,
        "isolatedModules": true,
        "allowSyntheticDefaultImports": true,
        "forceConsistentCasingInFileNames": true,
        "strict": true,
        "skipLibCheck": true,
        "declaration": false,
        "sourceMap": true,
        "types": ["@cloudflare/workers-types", "@bkper/bkper-api-types"]
    },
    "exclude": ["test", "node_modules"],
    "include": ["src/**/*.ts"]
}
